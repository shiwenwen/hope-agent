{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenComputer",
  "version": "0.1.0",
  "identifier": "com.opencomputer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "OpenComputer",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 8, "y": 18 },
        "width": 1200,
        "height": 800,
        "minWidth": 840,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "transparent": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "$HOME/**", "$HOME/.opencomputer/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
