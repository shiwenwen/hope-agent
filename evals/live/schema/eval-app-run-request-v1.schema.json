{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hope-agent.local/evals/eval-app-run-request-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId", "suiteSelections", "models", "campaignBudget", "debugRetention", "consent"],
  "properties": {
    "schemaVersion": { "const": "eval-app-run-request.v1" },
    "profileId": { "$ref": "#/$defs/identifier" },
    "suiteSelections": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["suiteId", "caseIds", "arms"],
        "properties": {
          "suiteId": { "$ref": "#/$defs/identifier" },
          "caseIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
          "arms": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
          "repetitions": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["providerId", "modelId"],
        "properties": {
          "providerId": { "$ref": "#/$defs/identifier" },
          "modelId": { "type": "string", "minLength": 1, "maxLength": 256 },
          "credentialProfileRef": { "$ref": "#/$defs/identifier" },
          "reasoningEffort": { "type": "string", "minLength": 1, "maxLength": 64 },
          "maxOutputTokens": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "campaignBudget": { "$ref": "#/$defs/budget" },
    "debugRetention": { "enum": ["metrics_only", "redacted", "full_local"] },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modelCosts", "syntheticToolExecution"],
      "properties": {
        "modelCosts": { "const": true },
        "syntheticToolExecution": { "const": true }
      }
    }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWallSeconds": { "type": "integer", "minimum": 1 },
        "maxModelCalls": { "type": "integer", "minimum": 1 },
        "maxInputTokens": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "maxCostUsd": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "maxToolCalls": { "type": "integer", "minimum": 1 },
        "maxAgents": { "type": "integer", "minimum": 1 },
        "maxConcurrency": { "type": "integer", "minimum": 1, "maximum": 2 }
      },
      "anyOf": [
        { "required": ["maxCostUsd"] },
        { "required": ["maxInputTokens"] },
        { "required": ["maxModelCalls"] }
      ]
    }
  }
}
