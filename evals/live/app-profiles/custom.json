{
  "schemaVersion": "eval-app-profile.v1",
  "id": "custom",
  "version": "1.1.0",
  "title": "Custom diagnosis",
  "description": "A user-selected subset of registered weekly cases and arms with bounded repetitions.",
  "baseTier": "weekly",
  "suites": [
    { "suiteId": "hope-core-orchestration", "caseTags": ["smoke_weekly"] }
  ],
  "allowedArms": [
    "control", "faulted", "team_full_control", "team_full_faulted",
    "single_agent_compute_matched_control", "single_agent_compute_matched_faulted"
  ],
  "armMode": "all_allowed",
  "defaultRepetitions": 1,
  "useSuiteRepetitions": false,
  "maxTrials": 500,
  "maxModels": 4,
  "maxConcurrency": 500,
  "maxCostUsd": 1000000,
  "allowCustom": true
}
